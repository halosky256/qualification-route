    const loadingLogs = [
      "やる気、逃亡を確認…",
      "現実サーバー、応答なし…",
      "将来不安、バックグラウンドで暴走中…",
      "だるさ、最大値を更新…",
      "今日の敵を無理やり召喚中…",
      "ログアウト空間へ避難中…",
      "通信先を変更中：現実 → 一旦ログアウト空間…"
    ];

    const $ = (id) => document.getElementById(id);
    const screens = {
      top: $("topScreen"),
      loading: $("loadingScreen"),
      result: $("resultScreen")
    };

    let currentEnemy = null;
    let lastIndex = -1;

    function showScreen(name) {
      Object.values(screens).forEach(s => s.classList.remove("active"));
      screens[name].classList.add("active");
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function pickEnemy() {
      let index = Math.floor(Math.random() * enemies.length);
      if (enemies.length > 1 && index === lastIndex) {
        index = (index + 1) % enemies.length;
      }
      lastIndex = index;
      return { ...enemies[index], index };
    }

    function startLogout() {
      showScreen("loading");
      $("barFill").style.width = "0%";
      $("logList").innerHTML = "";

      const logs = [...loadingLogs].sort(() => Math.random() - 0.5).slice(0, 5);
      let progress = 0;

      logs.forEach((text, i) => {
        setTimeout(() => {
          const div = document.createElement("div");
          div.className = "log active";
          div.textContent = text;
          $("logList").appendChild(div);
          progress = Math.min(100, progress + 20 + Math.floor(Math.random() * 8));
          $("barFill").style.width = progress + "%";
        }, i * 520);
      });

      setTimeout(() => {
        $("barFill").style.width = "100%";
      }, 2800);

      setTimeout(() => {
        currentEnemy = pickEnemy();
        renderResult(currentEnemy);
        showScreen("result");
      }, 3400);
    }

    function renderResult(enemy) {
      $("enemyName").textContent = enemy.name;
      $("enemyNo").textContent = "NO." + String(enemy.index + 1).padStart(3, "0");
      $("enemyLine").textContent = "「" + enemy.line + "」";
      $("mission").textContent = enemy.mission;
      $("message").textContent = enemy.message;
      $("monster").style.setProperty("--mood", enemy.color || "#9cff2e");
    }

    function showToast(text) {
      const toast = $("toast");
      toast.textContent = text;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 1800);
    }

    async function copyShareText() {
      if (!currentEnemy) return;
      const text = `現実一旦ログアウトした。\n今日の敵は「${currentEnemy.name}」だった。\n\n「${currentEnemy.line}」\n\n#現実一旦ログアウト #今日の敵`;
      try {
        await navigator.clipboard.writeText(text);
        showToast("シェア文をコピーしました");
      } catch (e) {
        showToast("コピーできませんでした");
      }
    }

    function wrapText(ctx, text, x, y, maxWidth, lineHeight, maxLines) {
      const chars = Array.from(text);
      let line = "";
      let lines = [];
      for (const ch of chars) {
        const test = line + ch;
        if (ctx.measureText(test).width > maxWidth && line !== "") {
          lines.push(line);
          line = ch;
          if (maxLines && lines.length >= maxLines) break;
        } else {
          line = test;
        }
      }
      if (!maxLines || lines.length < maxLines) lines.push(line);

      lines.slice(0, maxLines || lines.length).forEach((l, i) => {
        ctx.fillText(l, x, y + i * lineHeight);
      });
      return y + lines.length * lineHeight;
    }

    function drawRoundedRect(ctx, x, y, w, h, r) {
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + w, y, x + w, y + h, r);
      ctx.arcTo(x + w, y + h, x, y + h, r);
      ctx.arcTo(x, y + h, x, y, r);
      ctx.arcTo(x, y, x + w, y, r);
      ctx.closePath();
    }

    function downloadCard() {
      if (!currentEnemy) return;

      const canvas = $("resultCanvas");
      const ctx = canvas.getContext("2d");
      const W = canvas.width;
      const H = canvas.height;

      ctx.fillStyle = "#050805";
      ctx.fillRect(0, 0, W, H);

      // grid
      ctx.strokeStyle = "rgba(156,255,46,0.09)";
      ctx.lineWidth = 2;
      for (let x = 0; x < W; x += 48) {
        ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
      }
      for (let y = 0; y < H; y += 48) {
        ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
      }

      // panel
      drawRoundedRect(ctx, 70, 70, W - 140, H - 140, 44);
      ctx.fillStyle = "#081108";
      ctx.fill();
      ctx.strokeStyle = "rgba(156,255,46,0.45)";
      ctx.lineWidth = 4;
      ctx.stroke();

      ctx.fillStyle = "#9cff2e";
      ctx.font = "bold 44px system-ui, sans-serif";
      ctx.fillText("現実一旦ログアウト", 110, 150);

      ctx.fillStyle = "#a7b5a0";
      ctx.font = "28px system-ui, sans-serif";
      ctx.fillText("今日の敵、出現", 110, 205);

      // monster simple
      const cx = W / 2;
      const cy = 380;
      ctx.save();
      ctx.strokeStyle = currentEnemy.color || "#9cff2e";
      ctx.fillStyle = "rgba(156,255,46,0.14)";
      ctx.lineWidth = 8;
      ctx.beginPath();
      ctx.ellipse(cx, cy, 130, 112, -0.05, 0, Math.PI * 2);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = currentEnemy.color || "#9cff2e";
      ctx.beginPath(); ctx.arc(cx - 45, cy - 20, 16, 0, Math.PI * 2); ctx.fill();
      ctx.beginPath(); ctx.arc(cx + 45, cy - 20, 16, 0, Math.PI * 2); ctx.fill();

      ctx.strokeStyle = currentEnemy.color || "#9cff2e";
      ctx.lineWidth = 8;
      ctx.beginPath();
      ctx.arc(cx, cy + 34, 42, 0.05 * Math.PI, 0.95 * Math.PI);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(cx - 70, cy - 105);
      ctx.quadraticCurveTo(cx - 100, cy - 160, cx - 40, cy - 125);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(cx + 70, cy - 105);
      ctx.quadraticCurveTo(cx + 100, cy - 160, cx + 40, cy - 125);
      ctx.stroke();
      ctx.restore();

      ctx.fillStyle = "#f5fff1";
      ctx.font = "bold 64px system-ui, sans-serif";
      let nextY = wrapText(ctx, currentEnemy.name, 110, 595, W - 220, 78, 3);

      ctx.fillStyle = "#9cff2e";
      ctx.font = "bold 30px system-ui, sans-serif";
      ctx.fillText("ENEMY LINE", 110, nextY + 42);

      ctx.fillStyle = "#f5fff1";
      ctx.font = "bold 38px system-ui, sans-serif";
      nextY = wrapText(ctx, "「" + currentEnemy.line + "」", 110, nextY + 95, W - 220, 52, 2);

      ctx.fillStyle = "#9cff2e";
      ctx.font = "bold 30px system-ui, sans-serif";
      ctx.fillText("LOGOUT MISSION", 110, nextY + 54);

      ctx.fillStyle = "#f5fff1";
      ctx.font = "34px system-ui, sans-serif";
      nextY = wrapText(ctx, currentEnemy.mission, 110, nextY + 105, W - 220, 50, 4);

      ctx.fillStyle = "#9cff2e";
      ctx.font = "bold 30px system-ui, sans-serif";
      ctx.fillText("MESSAGE", 110, nextY + 60);

      ctx.fillStyle = "#f5fff1";
      ctx.font = "32px system-ui, sans-serif";
      nextY = wrapText(ctx, currentEnemy.message, 110, nextY + 110, W - 220, 48, 4);

      ctx.fillStyle = "#a7b5a0";
      ctx.font = "28px system-ui, sans-serif";
      ctx.fillText("#現実一旦ログアウト #今日の敵", 110, H - 145);

      const link = document.createElement("a");
      link.download = "genjitsu-logout-card.png";
      link.href = canvas.toDataURL("image/png");
      link.click();
      showToast("結果カードを保存しました");
    }

    $("logoutBtn").addEventListener("click", startLogout);
    $("againBtn").addEventListener("click", startLogout);
    $("shareBtn").addEventListener("click", copyShareText);
    $("saveBtn").addEventListener("click", downloadCard);
  </script>
